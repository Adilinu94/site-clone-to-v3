{
  "name": "site-clone-to-v3",
  "version": "0.1.0",
  "description": "Clone any live website to Elementor V3 — pixel-accurate, on any WordPress with the Novamira plugin.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "clone-v3": "./dist/cli/clone-v3.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "prepublishOnly": "npm run test:unit && npm run build",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "changelog": "tsx scripts/generate-changelog.ts",
    "dev": "tsx src/cli/clone-v3.ts",
    "start": "node dist/cli/clone-v3.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.11",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.5",
    "ssim.js": "^3.5.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "playwright-core": "^1.61.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "elementor",
    "elementor-v3",
    "elementor-v4",
    "wordpress",
    "novamira",
    "site-clone",
    "website-cloner",
    "framer",
    "reverse-engineering",
    "wp-cli",
    "oklch",
    "design-tokens",
    "pixel-diff",
    "pro-widget",
    "auto-fix",
    "mcp-adapter",
    "circuit-breaker"
  ],
  "author": "Adilinu94",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adilinu94/site-clone-to-v3.git"
  },
  "bugs": {
    "url": "https://github.com/Adilinu94/site-clone-to-v3/issues"
  },
  "homepage": "https://github.com/Adilinu94/site-clone-to-v3#readme",
  "publishConfig": {
    "access": "public"
  }
}
